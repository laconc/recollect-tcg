# Copy this to `config.toml` (same directory) to opt in to faster local builds with the LLVM lld
# linker — it's much faster at the link step, and this workspace links ~29 test binaries per
# `make test` (down from ~73 before the #106 consolidation). Requires `brew install lld` so
# `ld64.lld` is on PATH.
#
# `config.toml` is gitignored, so this is per-developer: contributors without lld just build with
# the system linker and nothing breaks. No effect on the produced binaries.
#
# Apple Silicon below; on an Intel Mac use `[target.x86_64-apple-darwin]`, on Linux
# `[target.x86_64-unknown-linux-gnu]` with `mold` or `lld`.
[target.aarch64-apple-darwin]
rustflags = ["-C", "link-arg=-fuse-ld=lld"]
