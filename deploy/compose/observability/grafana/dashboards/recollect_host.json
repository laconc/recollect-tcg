      "id": 1,
      "options": {
        "code": {
          "language": "plaintext",
          "showLineNumbers": false,
          "showMiniMap": false
        },
        "content": "# Recollect \u2014 host / box\nCPU / memory / **swap** / disk for the 1 GB launch box, from the `node-exporter` sidecar (scraped by the on-box Prometheus, job `node-exporter`). **Swap matters most here** \u2014 the self-hosted LGTM stack leans on the 4 GB swap file on `/data`; the swap panel + the `recollect-swap-high` CloudWatch alarm are the canaries (if swap thrashes, the fallback is `t3.small`).",
        "mode": "markdown"
      },
      "pluginVersion": "10.3.3",
      "title": "",
      "type": "text"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "100 - idle. The recollect-cpu-high CloudWatch alarm watches the EC2-side equivalent.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 6,
